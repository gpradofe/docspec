<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.waypoint</groupId>
    <artifactId>waypoint-engine</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>Waypoint Curriculum Engine</name>
    <description>AI-powered curriculum generation engine — DocSpec Tier 2 example with full annotations</description>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- DocSpec annotations for Tier 2 documentation -->
        <dependency>
            <groupId>io.docspec</groupId>
            <artifactId>docspec-annotations-java</artifactId>
            <version>1.0.0-SNAPSHOT</version>
        </dependency>

        <!-- Spring Boot — provided scope, only need annotations on classpath -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <version>3.2.3</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
            <version>3.2.3</version>
            <scope>provided</scope>
        </dependency>

        <!-- Jackson — provided scope, only need annotations on classpath -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <version>2.17.0</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.12.1</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                </configuration>
            </plugin>

            <!-- DocSpec Maven Plugin — generate, validate, and coverage goals -->
            <plugin>
                <groupId>io.docspec</groupId>
                <artifactId>docspec-maven-plugin</artifactId>
                <version>1.0.0-SNAPSHOT</version>
                <configuration>
                    <discovery>
                        <mode>hybrid</mode>
                        <includes>
                            <include>com.waypoint.**</include>
                        </includes>
                        <frameworks>
                            <spring>true</spring>
                            <jpa>true</jpa>
                            <jackson>true</jackson>
                        </frameworks>
                        <inferDescriptions>true</inferDescriptions>
                        <dsti>
                            <enabled>true</enabled>
                        </dsti>
                    </discovery>
                    <coverage>
                        <minimumPercent>80</minimumPercent>
                        <failOnBelowThreshold>true</failOnBelowThreshold>
                    </coverage>
                </configuration>
                <executions>
                    <execution>
                        <id>docspec-generate</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>docspec-validate</id>
                        <goals>
                            <goal>validate</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>docspec-coverage</id>
                        <goals>
                            <goal>coverage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
