{
  "framework": "nestjs",
  "language": "typescript",
  "version": "10.x",
  "stereotypes": {
    "@Controller": { "kind": "controller", "stereotype": "api", "endpoint": true },
    "@Injectable": { "kind": "service", "stereotype": "service" },
    "@Module": { "kind": "config", "stereotype": "configuration" }
  },
  "endpointDecorators": ["@Get", "@Post", "@Put", "@Delete", "@Patch"],
  "diDecorators": ["@Inject"],
  "guardDecorators": ["@UseGuards"],
  "interceptorDecorators": ["@UseInterceptors"],
  "pipeDecorators": ["@UsePipes"]
}
