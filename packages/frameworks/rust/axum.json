{
  "framework": "axum",
  "language": "rust",
  "version": "0.7.x",
  "routerPatterns": {
    "Router::new().route": "endpoint",
    "get(": "GET", "post(": "POST", "put(": "PUT", "delete(": "DELETE", "patch(": "PATCH"
  },
  "extractors": ["Json", "Query", "Path", "State", "Extension"],
  "middlewarePatterns": ["layer(", "ServiceBuilder"]
}
