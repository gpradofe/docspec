{
  "framework": "aspnet-core",
  "language": "csharp",
  "version": "8.0+",
  "stereotypes": {
    "Controller": {
      "attributes": ["ApiController", "Controller"],
      "baseClasses": ["ControllerBase", "Controller"],
      "kind": "controller",
      "endpointDetection": {
        "attributes": ["HttpGet", "HttpPost", "HttpPut", "HttpDelete", "HttpPatch"],
        "routeAttribute": "Route"
      }
    },
    "Service": {
      "registration": ["AddScoped", "AddTransient", "AddSingleton"],
      "interfaces": true,
      "kind": "service"
    },
    "Middleware": {
      "interfaces": ["IMiddleware"],
      "method": "InvokeAsync",
      "kind": "middleware"
    },
    "BackgroundService": {
      "baseClasses": ["BackgroundService", "IHostedService"],
      "kind": "scheduled"
    }
  },
  "dataModels": {
    "detection": ["EntityTypeConfiguration", "DbSet"],
    "attributes": ["Table", "Key", "Column", "Required", "MaxLength", "ForeignKey"],
    "relationships": ["HasOne", "HasMany", "ManyToMany"]
  },
  "configuration": {
    "pattern": "IOptions<T>",
    "sources": ["appsettings.json", "appsettings.*.json"],
    "binding": "Configure<T>"
  }
}
