{
  "framework": "prisma",
  "language": "typescript",
  "version": "5.x",
  "schemaFile": "prisma/schema.prisma",
  "modelDirectives": { "model": "entity", "enum": "enum", "type": "dto" },
  "fieldAttributes": {
    "@id": { "primaryKey": true },
    "@default(autoincrement())": { "generated": true },
    "@default(uuid())": { "generated": true },
    "@unique": { "unique": true },
    "@relation": { "relationship": true }
  }
}
