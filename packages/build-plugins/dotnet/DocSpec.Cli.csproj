<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <RootNamespace>DocSpec.Cli</RootNamespace>

    <!-- dotnet tool metadata -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>docspec</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>

    <!-- NuGet package metadata -->
    <PackageId>DocSpec.Cli</PackageId>
    <Version>0.1.0</Version>
    <Authors>DocSpec Contributors</Authors>
    <Description>DocSpec CLI for .NET — generate, validate, and check coverage of documentation specifications from C# source code</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://docspec.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/docspec/docspec</RepositoryUrl>
    <PackageTags>documentation;docspec;code-analysis;roslyn</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
    <PackageReference Include="System.Text.Json" Version="8.0.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" />
    <PackageReference Include="Json.Schema.Net" Version="6.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\processor\csharp\DocSpec.Analyzer.csproj" />
  </ItemGroup>

  <!-- Bundle the schema as an embedded resource -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\spec\docspec.schema.json" Link="docspec.schema.json" LogicalName="DocSpec.Cli.docspec.schema.json" />
  </ItemGroup>
</Project>
