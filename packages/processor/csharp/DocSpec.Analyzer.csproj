<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <RootNamespace>DocSpec.Analyzer</RootNamespace>
    <PackageId>DocSpec.Analyzer</PackageId>
    <Version>0.1.0</Version>
    <Description>DocSpec Roslyn analyzer for C# projects</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" />
    <PackageReference Include="System.Text.Json" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\annotations\csharp\DocSpec.Annotations.csproj" />
  </ItemGroup>
</Project>
